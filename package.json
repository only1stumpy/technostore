{
  "name": "diplom",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "check": "bun run typecheck && bun run lint && bun test",
    "db:generate": "bunx --bun prisma generate",
    "db:migrate:dev": "bunx --bun prisma migrate dev",
    "db:migrate:deploy": "bunx --bun prisma migrate deploy",
    "db:migrate:status": "bunx --bun prisma migrate status",
    "db:seed": "bun prisma/seed.ts",
    "postinstall": "bunx --bun prisma generate"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/extension-accelerate": "^3.0.1",
    "@upstash/redis": "^1.38.0",
    "clsx": "^2.1.1",
    "docx": "^9.7.1",
    "dotenv": "^17.4.2",
    "jose": "^6.2.3",
    "next": "16.2.6",
    "pg": "^8.21.0",
    "postcss": "^8.5.14",
    "pptxgenjs": "^4.0.1",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^20.19.41",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.6",
    "prisma-erd-generator": "^2.4.2",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3"
  }
}
